{
  "manifest_version": 3,
  "name": "System Monitor",
  "description": "A lightweight click-to-open system monitor popup.",
  "version": "0.1.0",
  "action": {
    "default_title": "System Monitor",
    "default_popup": "src/popup.html",
    "default_icon": "icons/icon.svg"
  },
  "icons": { "128": "icons/icon.svg" },
  "permissions": [
    "system.cpu",
    "system.memory",
    "system.storage",
    "system.display"
  ]
}
